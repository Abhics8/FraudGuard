# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# Database
DATABASE_URL=sqlite:///./fraud_detection.db

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Model Configuration
MODEL_TYPE=xgboost
THRESHOLD=0.5

# Monitoring
DRIFT_THRESHOLD=0.05
ENABLE_MONITORING=True

# Paths
DATA_PATH=./data
MODEL_PATH=./models
MLRUNS_PATH=./mlruns
