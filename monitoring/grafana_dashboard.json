{
    "dashboard": {
        "title": "RiskLens - Fraud Detection Monitoring",
        "tags": [
            "risklens",
            "fraud-detection",
            "ml"
        ],
        "timezone": "browser",
        "panels": [
            {
                "title": "API Requests Rate",
                "type": "graph",
                "targets": [
                    {
                        "expr": "rate(risklens_api_requests_total[5m])",
                        "legendFormat": "{{method}} {{endpoint}} - {{status}}"
                    }
                ],
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 0,
                    "y": 0
                }
            },
            {
                "title": "API Request Duration (p95)",
                "type": "graph",
                "targets": [
                    {
                        "expr": "histogram_quantile(0.95, rate(risklens_api_request_duration_seconds_bucket[5m]))",
                        "legendFormat": "{{endpoint}}"
                    }
                ],
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 12,
                    "y": 0
                }
            },
            {
                "title": "Predictions Per Minute",
                "type": "graph",
                "targets": [
                    {
                        "expr": "rate(risklens_predictions_total[1m]) * 60",
                        "legendFormat": "{{prediction_type}}"
                    }
                ],
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 0,
                    "y": 8
                }
            },
            {
                "title": "Fraud Detection Rate",
                "type": "singlestat",
                "targets": [
                    {
                        "expr": "rate(risklens_fraud_detected_total[5m])"
                    }
                ],
                "gridPos": {
                    "h": 8,
                    "w": 6,
                    "x": 12,
                    "y": 8
                }
            },
            {
                "title": "Fraud Probability Distribution",
                "type": "heatmap",
                "targets": [
                    {
                        "expr": "rate(risklens_fraud_probability_bucket[5m])"
                    }
                ],
                "gridPos": {
                    "h": 8,
                    "w": 6,
                    "x": 18,
                    "y": 8
                }
            },
            {
                "title": "Model Prediction Latency (p50, p95, p99)",
                "type": "graph",
                "targets": [
                    {
                        "expr": "histogram_quantile(0.50, rate(risklens_prediction_latency_seconds_bucket[5m]))",
                        "legendFormat": "p50"
                    },
                    {
                        "expr": "histogram_quantile(0.95, rate(risklens_prediction_latency_seconds_bucket[5m]))",
                        "legendFormat": "p95"
                    },
                    {
                        "expr": "histogram_quantile(0.99, rate(risklens_prediction_latency_seconds_bucket[5m]))",
                        "legendFormat": "p99"
                    }
                ],
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 0,
                    "y": 16
                }
            },
            {
                "title": "Model Status",
                "type": "singlestat",
                "targets": [
                    {
                        "expr": "risklens_model_loaded"
                    }
                ],
                "valueMaps": [
                    {
                        "value": "1",
                        "text": "Loaded"
                    },
                    {
                        "value": "0",
                        "text": "Not Loaded"
                    }
                ],
                "gridPos": {
                    "h": 4,
                    "w": 6,
                    "x": 12,
                    "y": 16
                }
            },
            {
                "title": "Data Drift Status",
                "type": "singlestat",
                "targets": [
                    {
                        "expr": "risklens_data_drift_detected"
                    }
                ],
                "valueMaps": [
                    {
                        "value": "1",
                        "text": "Drift Detected"
                    },
                    {
                        "value": "0",
                        "text": "No Drift"
                    }
                ],
                "gridPos": {
                    "h": 4,
                    "w": 6,
                    "x": 18,
                    "y": 16
                }
            },
            {
                "title": "Drift Share",
                "type": "gauge",
                "targets": [
                    {
                        "expr": "risklens_drift_share"
                    }
                ],
                "gridPos": {
                    "h": 4,
                    "w": 6,
                    "x": 12,
                    "y": 20
                }
            }
        ]
    }
}